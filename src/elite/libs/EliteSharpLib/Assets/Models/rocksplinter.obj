# rocksplinter
# Converted from rocksplinter.json - Elite: The Sharp Kind
# 'pn' comments link a vertex to a face-normal-pool ('vn') entry that
# no face uses directly; only the explosion debris effect reads these.
mtllib palette.mtl

v -24 -25 16
v 0 12 -10
v 11 -6 2
v 12 42 7

vn 30 0 0
vn 22 32 -8
vn 0 2 0
vn 17 23 95

usemtl LightGrey
f 4 3 2
usemtl DarkGrey
f 1 3 4
usemtl DarkerGrey
f 4 2 1
usemtl Grey
f 1 2 3

