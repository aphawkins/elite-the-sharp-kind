# escapecapsule
# Converted from escapecapsule.json - Elite: The Sharp Kind
# 'pn' comments link a vertex to a face-normal-pool ('vn') entry that
# no face uses directly; only the explosion debris effect reads these.
mtllib palette.mtl

v -7 0 36
v -7 -14 -12
v -7 14 -12
v 21 0 0

vn 52 0 -122
vn 39 103 30
vn 39 -103 30
vn -112 0 0

usemtl LighterRed
f 4 2 3
usemtl LightRed
f 1 4 3
usemtl Red
f 1 2 4
usemtl RedOrange
f 1 3 2

